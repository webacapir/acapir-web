<script>
  /* ── Visor PDF ───────────────────────────────────────────────── */
  var PDF_URL = 'https://zenodo.org/records/20686884/files/informe-salut-mental-catalunya-scpc-acapir-2026.pdf';

  function launchPdfViewer() {
    var container = document.getElementById('pdf-viewer-container');
    var launcher = document.getElementById('pdf-launcher');
    var frameWrap = document.getElementById('pdf-frame-wrap');
    var blocked = document.getElementById('pdf-blocked');

    // Mostrar el contenidor
    launcher.style.display = 'none';
    container.style.display = 'block';

    // Crear l'iframe
    var iframe = document.createElement('iframe');
    iframe.src = PDF_URL;
    iframe.style.width = '100%';
    iframe.style.height = '780px';
    iframe.style.border = 'none';
    iframe.style.display = 'block';

    // Detectar si Zenodo bloqueja l'iframe
    iframe.onload = function() {
      try {
        // Si l'iframe carrega correctament, amaguem el fallback
        blocked.style.display = 'none';
        frameWrap.style.display = 'block';
      } catch(e) {
        // Error de cross-origin = bloquejat
        frameWrap.style.display = 'none';
        blocked.style.display = 'block';
      }
    };

    // Timeout: si no carrega en 5 segons, mostrar fallback
    setTimeout(function() {
      if (iframe.contentDocument === null || iframe.contentDocument.body === null) {
        // Possiblement bloquejat
      }
      // Comprovació per headers X-Frame-Options
      // Si el iframe és molt petit o buit, mostrar fallback
    }, 5000);

    frameWrap.appendChild(iframe);

    // Scroll suau fins al visor
    setTimeout(function() {
      container.scrollIntoView({ behavior: 'smooth', block: 'start' });
    }, 100);
  }

  function closePdfViewer() {
    document.getElementById('pdf-viewer-container').style.display = 'none';
    document.getElementById('pdf-launcher').style.display = 'block';
    document.getElementById('pdf-frame-wrap').innerHTML = '';
    document.getElementById('pdf-blocked').style.display = 'none';
    document.getElementById('visor-pdf').scrollIntoView({ behavior: 'smooth' });
  }

  /* ── Canvi d'idioma: setLang no existeix a base.njk, cal definir-la aquí ── */
  function setLang(lang) {
    document.body.classList.toggle('lang-es', lang === 'es');
    var btnCa = document.getElementById('btn-ca');
    var btnEs = document.getElementById('btn-es');
    if (btnCa) btnCa.classList.toggle('active', lang === 'ca');
    if (btnEs) btnEs.classList.toggle('active', lang === 'es');
    document.documentElement.lang = lang === 'es' ? 'es' : 'ca';
    try { localStorage.setItem('acapir-lang', lang); } catch(e) {}
  }

  function infAcc(btn) {
    var body = btn.nextElementSibling;
    var open = body.style.display !== 'none';
    body.style.display = open ? 'none' : 'block';
    btn.querySelector('.inf-acc-icon').textContent = open ? '+' : '−';
  }

  document.addEventListener('DOMContentLoaded', function() {
    /* Restaurar idioma guardat */
    try {
      var saved = localStorage.getItem('acapir-lang');
      if (saved === 'es') setLang('es');
    } catch(e) {}

    /* Nav links → home */
    document.querySelectorAll('.topnav-link').forEach(function(link) {
      var href = link.getAttribute('href') || '';
      if (href.startsWith('#')) {
        link.setAttribute('href', '/' + href);
        link.onclick = function(e) { e.preventDefault(); window.location.href = '/' + href; };
      }
    });
    /* Contacte → home#contacte */
    var cBtn = document.querySelector('.topnav-btn-contacte');
    if (cBtn) {
      cBtn.href = '/#contacte';
      cBtn.onclick = function(e) { e.preventDefault(); window.location.href = '/#contacte'; };
    }
    /* Logo → home */
    var logo = document.querySelector('#topnav img');
    if (logo) logo.onclick = function() { window.location.href = '/'; };
  });
</script>
