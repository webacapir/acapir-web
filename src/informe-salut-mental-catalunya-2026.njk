<script>
  function accToggle(btn) {
    var body = btn.nextElementSibling;
    var open = body.style.display !== 'none';
    body.style.display = open ? 'none' : 'block';
    btn.querySelector('.acc-icon').textContent = open ? '+' : '−';
  }

  // Fer que els links del topnav vagin a la home + les seccions
  document.addEventListener('DOMContentLoaded', function() {
    document.querySelectorAll('.topnav-link').forEach(function(link) {
      var href = link.getAttribute('href') || '';
      if (href.startsWith('#')) {
        link.setAttribute('href', '/' + href);
        link.onclick = function(e) {
          e.preventDefault();
          window.location.href = '/' + href;
        };
      }
    });
    // El logo va a la home
    var logoImg = document.querySelector('#topnav img');
    if (logoImg) {
      logoImg.onclick = function() { window.location.href = '/'; };
    }
    // Scroll suau per al botó "Com citar"
    document.querySelectorAll('a[href="#com-citar"]').forEach(function(a) {
      a.addEventListener('click', function(e) {
        e.preventDefault();
        document.getElementById('com-citar').scrollIntoView({ behavior: 'smooth' });
      });
    });
  });
</script>
