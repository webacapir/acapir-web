<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1200 630">
  <rect width="1200" height="630" fill="#000"/>
  <rect x="0" y="0" width="6" height="630" fill="#4ADDD5"/>
  <!-- Fons subtil -->
  <text x="60" y="580" font-family="Helvetica Neue, Arial" font-size="11" font-weight="700"
    fill="rgba(255,255,255,.15)" letter-spacing="3">
    SCPC-ACAPIR · SOCIETAT CATALANA DE PSICOLOGIA CLÍNICA
  </text>
  <!-- Xifra gran -->
  <text x="60" y="200" font-family="Helvetica Neue, Arial" font-size="160" font-weight="800"
    fill="#4ADDD5" opacity=".15">+80%</text>
  <!-- Títol -->
  <text x="60" y="160" font-family="Helvetica Neue, Arial" font-size="13" font-weight="700"
    fill="#4ADDD5" letter-spacing="3">INFORME · JUNY 2026</text>
  <text x="60" y="260" font-family="Helvetica Neue, Arial" font-size="52" font-weight="800"
    fill="#fff">La salut mental a Catalunya:</text>
  <text x="60" y="325" font-family="Helvetica Neue, Arial" font-size="52" font-weight="800"
    fill="#fff">entre el discurs institucional</text>
  <text x="60" y="390" font-family="Helvetica Neue, Arial" font-size="52" font-weight="800"
    fill="#fff">i la pràctica real</text>
  <!-- Dada -->
  <text x="60" y="460" font-family="Helvetica Neue, Arial" font-size="18" font-weight="300"
    fill="rgba(255,255,255,.7)">Basat en una enquesta a 146 psicòlegs clínics de la xarxa pública catalana</text>
  <!-- DOI -->
  <text x="60" y="530" font-family="Helvetica Neue, Arial" font-size="13" font-weight="400"
    fill="rgba(255,255,255,.4)">DOI: 10.5281/zenodo.20686884 · ISBN: 978-84-09-87424-8 · CC BY-NC-SA 4.0</text>
</svg>