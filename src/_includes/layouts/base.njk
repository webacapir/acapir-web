<!DOCTYPE html>
<html lang="ca">
<head>
  <meta charset="UTF-8" />
  <meta name="theme-color" content="#4ADDD5">
  <meta name="apple-mobile-web-app-capable" content="yes">
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <link rel="icon" type="image/svg+xml" href="/assets/favicon.svg">

  <!-- SEO -->
  <title>{{ config.seo.titol }}</title>
  <meta name="description" content="{{ config.seo.descripcio_ca }} {{ config.seo.descripcio_es }}">
  <meta name="keywords" content="{{ config.seo.paraules_clau }}">
  <link rel="canonical" href="https://acapir.cat">

  <!-- Hreflang bilingüe -->
  <link rel="alternate" hreflang="ca" href="https://acapir.cat">
  <link rel="alternate" hreflang="es" href="https://acapir.cat">
  <link rel="alternate" hreflang="x-default" href="https://acapir.cat">

  <!-- Open Graph -->
  <meta property="og:type" content="website">
  <meta property="og:url" content="https://acapir.cat">
  <meta property="og:title" content="{{ config.seo.titol }}">
  <meta property="og:description" content="{{ config.seo.descripcio_ca }}">
  <meta property="og:image" content="https://acapir.cat/assets/img/informe-2026.jpg">
  <meta property="og:locale" content="ca_ES">
  <meta property="og:locale:alternate" content="es_ES">
  <meta property="twitter:card" content="summary_large_image">
  <meta property="twitter:title" content="{{ config.seo.titol }}">
  <meta property="twitter:description" content="{{ config.seo.descripcio_ca }}">
  <meta property="twitter:image" content="https://acapir.cat/assets/img/informe-2026.jpg">

  <style>

    :root {
      --tq:       #4ADDD5;
      --black:    #000;
      --white:    #fff;
      --band-h:   clamp(64px, 12vh, 110px);
      --band-gap: clamp(6px, 0.8vw, 12px);
      --coin-d:   48px;
    }
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { scroll-behavior: smooth; }
    body {
      font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
      background: #fff; color: #000;
      -webkit-font-smoothing: antialiased;
    }

    /* ── Idioma ───────────────────────────────────────────── */
    [data-lang="es"] { display: none !important; }
    body.lang-es [data-lang="ca"] { display: none !important; }
    body.lang-es [data-lang="es"] { display: inline !important; }
    /* Asegurar ocultación de spans block en ES */
    body.lang-es span[data-lang="ca"],
    body.lang-es div[data-lang="ca"] { display: none !important; }
    body.lang-es span[data-lang="es"],
    body.lang-es div[data-lang="es"] { display: inline !important; }
    .lang-btn { background: none; border: none; cursor: pointer;
      font-size: 13px; letter-spacing: 0.08em; padding: 8px 6px;
      font-family: inherit; }
    .lang-btn.active { color: #000; font-weight: 700; }
    .lang-btn:not(.active) { color: #999; }

    /* ── Topnav ───────────────────────────────────────────── */
    #topnav {
      position: fixed; top: 0; left: 0; right: 0; z-index: 200;
      height: 80px; display: flex; align-items: center;
      justify-content: space-between; padding: 0 40px;
      background: transparent; border-bottom: 1px solid transparent;
      transition: height .4s, background .35s, border-color .35s, padding .4s;
    }
    #topnav img { height: 68px; width: auto; display: block;
      transition: height .4s; }
    .junta-cell img { width: 68px !important; height: 68px !important; }
    #topnav.solid {
      height: 52px; padding: 0 28px;
      background: rgba(255,255,255,.96);
      backdrop-filter: blur(12px);
      border-bottom-color: rgba(0,0,0,.08);
      box-shadow: 0 2px 20px rgba(0,0,0,.06);
    }
    #topnav.solid img { height: 28px; }
    .topnav-nav { display: flex; align-items: center; gap: 28px; }
    .topnav-link {
      font-size: 11px; font-weight: 600; letter-spacing: .07em;
      text-transform: uppercase; color: #000; text-decoration: none;
      border-bottom: 1px solid transparent; padding-bottom: 1px;
      transition: border-color .2s;
    }
    .topnav-link:hover { border-bottom-color: var(--tq); }
    .topnav-controls { display: flex; align-items: center; gap: 14px; }
    .btn-tq {
      background: var(--tq); color: #000; font-weight: 700;
      font-size: 11px; letter-spacing: .06em; text-transform: uppercase;
      padding: 8px 18px; border: 1.5px solid var(--tq); cursor: pointer;
      display: inline-flex; align-items: center; gap: 6px;
      text-decoration: none;
      transition: background .2s, color .2s, box-shadow .2s;
    }
    .btn-tq:hover { background: #000; color: var(--tq); border-color: #000;
      box-shadow: 3px 3px 0 var(--tq); }

    /* ── HERO ─────────────────────────────────────────────── */
    #hero {
      padding-top: 80px;
      display: flex;
      flex-direction: column;
      background: #f8f8f8;
    }
    /* Pequeño respiro antes del primer negro en móvil */
    @media (max-width: 900px) {
      #hero { background: #f8f8f8; }
      .hero-bands { padding-top: clamp(32px,6vh,64px); }
    }

    /* ── FRANGES ──────────────────────────────────────────── */
    .hero-bands {
      display: flex;
      flex-direction: column;
      gap: var(--band-gap);
      padding: clamp(48px,8vh,100px) clamp(20px,5vw,80px) 0;
      position: relative; /* contexto para el coin */
    }

    /* Coin: vive dentro de .hero-bands, se mueve entre franges */

    /* Cada franja */
    button { font-family: inherit; touch-action: manipulation; }
    a { touch-action: manipulation; }
    .band {
      position: relative;
      display: flex;
      align-items: center;
      gap: clamp(16px, 3vw, 40px);
      height: var(--band-h);
      cursor: pointer;
      background: #000;
      border: none;
      width: 100%;
      text-align: left;
      -webkit-appearance: none;
      appearance: none;
      overflow: hidden;
      padding: 0 clamp(20px,3.5vw,48px);
      touch-action: manipulation;
      -webkit-tap-highlight-color: transparent;
    }
    /* Revelado turquesa: barre desde la izquierda por detrás del texto */
    .band::before {
      content: '';
      position: absolute;
      inset: 0;
      background: var(--tq);
      transform: scaleX(0);
      transform-origin: left center;
      transition: transform .45s cubic-bezier(.4,0,.2,1);
      z-index: 0;
    }
    .band:hover::before,
    .band.active::before { transform: scaleX(1); }
    .band:focus-visible { outline: 2px solid var(--tq); outline-offset: -3px; }

    /* Número de sección */
    .band-num {
      position: relative;
      z-index: 2;
      font-size: clamp(13px, 1.4vw, 18px);
      font-weight: 700;
      letter-spacing: .05em;
      color: var(--tq);
      flex-shrink: 0;
      width: clamp(28px, 3vw, 44px);
      transition: color .3s;
    }
    .band:hover .band-num,
    .band.active .band-num { color: #000; }

    /* Texto de la franja — SIEMPRE VISIBLE */
    .band-content-wrap {
      position: relative;
      z-index: 2;
      display: flex;
      flex-direction: column;
    }
    .band-title {
      font-size: clamp(22px,3.2vw,44px);
      font-weight: 800;
      letter-spacing: -.03em;
      color: #fff;
      line-height: 1;
      display: block;
      transition: color .3s;
    }
    
    @keyframes splash {
      0%   { transform: scale(0); opacity: 1; }
      100% { transform: scale(4); opacity: 0; }
    }

    /* ── SECCIONES ────────────────────────────────────────── */
    .section-pad { padding: 88px 0; }
    .content-width { max-width: 1160px; margin: 0 auto; padding: 0 60px; }

    .section-eyebrow {
      font-size: 10px; letter-spacing: .2em; text-transform: uppercase;
      font-weight: 700; opacity: .4; margin-bottom: 10px;
    }
    .section-dark .section-eyebrow,
    .section-tq .section-eyebrow { opacity: 1; }
    .section-dark .section-eyebrow { color: rgba(255,255,255,.45); }
    .section-tq .section-eyebrow { color: rgba(0,0,0,.45); }

    .section-title {
      font-size: clamp(2rem,4.5vw,3.8rem);
      font-weight: 800; line-height: 1; letter-spacing: -.02em;
    }
    .accent-line { width: 36px; height: 3px; background: var(--tq); margin-bottom: 20px; }
    .section-dark .accent-line { background: var(--tq); }
    .section-tq .accent-line { background: #000; }
    .section-divider { height: 1px; background: #e8e8e8; }

    /* Section header con círculo */
    .section-header {
      display: flex; align-items: center; gap: 20px; margin-bottom: 44px;
    }
    .section-dark
    .section-header-text { display: flex; flex-direction: column; }

    /* Cards */
    .work-card {
      border: 1px solid #e0e0e0; padding: 28px;
      transition: border-color .25s, box-shadow .25s; background: #fff;
    }
    .work-card:hover { border-color: #000; box-shadow: 3px 3px 0 #000; }
    .work-card.accent { background: var(--tq); border-color: var(--tq); }
    .work-card.accent:hover { box-shadow: 3px 3px 0 #000; border-color: #000; }
    .work-card.featured { border-color: #000; border-width: 1.5px; }
    .work-card.featured:hover { box-shadow: 3px 3px 0 var(--tq); }

    .news-card {
      overflow: hidden; background: #fff; border: 1px solid #e0e0e0;
      transition: border-color .25s, box-shadow .25s;
    }
    .news-card:hover { border-color: #000; box-shadow: 3px 3px 0 #000; }
    .news-card-featured { border-color: #000; }

    .resource-card {
      border: 1px solid rgba(255,255,255,.15); padding: 28px;
      transition: border-color .25s, background .25s;
    }
    .resource-card:hover { border-color: var(--tq); background: rgba(74,221,213,.06); }

    /* Buttons */
    .btn-outline-black {
      background: transparent; color: #000; font-weight: 600;
      font-size: 11px; letter-spacing: .06em; text-transform: uppercase;
      padding: 9px 18px; border: 1.5px solid #000; cursor: pointer;
      display: inline-flex; align-items: center; gap: 6px; text-decoration: none;
      transition: background .2s, color .2s;
    }
    .btn-outline-black:hover { background: #000; color: #fff; }
    .btn-outline-white {
      background: transparent; color: #fff; font-weight: 600;
      font-size: 11px; letter-spacing: .06em; text-transform: uppercase;
      padding: 9px 18px; border: 1.5px solid rgba(255,255,255,.35); cursor: pointer;
      display: inline-flex; align-items: center; gap: 6px; text-decoration: none;
      transition: border-color .2s, color .2s;
    }
    .btn-outline-white:hover { border-color: var(--tq); color: var(--tq); }

    /* Junta */
    .junta-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(190px,1fr));
      border-top: 1px solid #e0e0e0; border-left: 1px solid #e0e0e0;
    }
    .junta-cell {
      padding: 18px 20px;
      border-right: 1px solid #e0e0e0; border-bottom: 1px solid #e0e0e0;
      background: #fff; transition: background .2s;
    }
    .junta-cell:hover { background: #fafafa; }
    .junta-cell.is-vocal { background: #f7fffe; }
    .junta-cell.is-vocal:hover { background: #eef9f9; }
    .junta-role {
      font-size: 10px; letter-spacing: .14em; text-transform: uppercase;
      font-weight: 700; opacity: .38; margin-bottom: 5px;
    }
    .junta-cell.is-vocal .junta-role { color: #2bc5bc; opacity: 1; }
    .junta-name { font-size: 14px; font-weight: 600; }

    .sub-strip {
      background: #f5f5f5; border: 1px solid #e0e0e0; padding: 28px 32px;
      display: flex; align-items: center; justify-content: space-between;
      gap: 20px; flex-wrap: wrap;
    }

    .video-card {
      background: rgba(255,255,255,.05);
      border: 1px solid rgba(255,255,255,.12);
      overflow: hidden; transition: border-color .3s;
    }
    .video-card:hover { border-color: rgba(74,221,213,.5); }
    .video-thumbnail {
      background: #111; height: 200px;
      display: flex; align-items: center; justify-content: center;
      position: relative; overflow: hidden;
    }
    .play-btn {
      width: 52px; height: 52px; background: var(--tq);
      border-radius: 50%; display: flex; align-items: center;
      justify-content: center; transition: transform .3s;
    }
    .play-btn:hover { transform: scale(1.1); }



    /* ── Franja de novetat ──────────────────────────────── */
    .news-band {
      position: relative;
      margin-top: calc(var(--band-gap) * 2);
      height: var(--band-h);
      display: flex;
      align-items: center;
      gap: clamp(16px,3vw,40px);
      padding: 0 clamp(20px,5vw,80px);
      cursor: pointer;
      text-decoration: none;
      overflow: hidden;
      touch-action: manipulation;
      -webkit-tap-highlight-color: transparent;
    }
    .news-band-bg {
      position: absolute; inset: 0;
      background-size: cover;
      background-position: center 30%;
      filter: brightness(.32) saturate(.6);
      transition: filter .4s ease;
      z-index: 0;
    }
    .news-band:hover .news-band-bg { filter: brightness(.45) saturate(.8); }
    .news-band-coin {
      position: relative; z-index: 2;
      flex-shrink: 0;
      width: 48px; height: 48px;
      border-radius: 50%;
      background: var(--tq);
      display: flex; flex-direction: column;
      align-items: center; justify-content: center;
      text-align: center; padding: 6px;
    }
    .news-band-coin-label {
      font-size: 7px; font-weight: 800;
      letter-spacing: .12em; text-transform: uppercase;
      color: #000; line-height: 1; margin-bottom: 2px;
    }
    .news-band-coin-date { font-size: 6.5px; color: rgba(0,0,0,.6); line-height: 1; }
    .news-band-text { position: relative; z-index: 2; display: flex; flex-direction: column; gap: 3px; }
    .news-band-eyebrow {
      font-size: 10px; font-weight: 700;
      letter-spacing: .14em; text-transform: uppercase;
      color: var(--tq); line-height: 1;
    }
    .news-band-title {
      font-size: clamp(14px,1.6vw,20px); font-weight: 800;
      letter-spacing: -.02em; color: #fff; line-height: 1.15;
    }
    .news-band-sub {
      font-size: clamp(11px,.9vw,13px); font-weight: 300;
      color: rgba(255,255,255,.55); line-height: 1.4;
    }
    
      .news-band-coin { width: 38px; height: 38px; }
    }


    /* ── Millores generals ──────────────────────────────── */
    .news-card { transition: box-shadow .2s ease; }
    .news-card:hover { box-shadow: 0 4px 20px rgba(0,0,0,.08); }
    .resource-card { transition: border-color .2s ease; }
    .resource-card:hover { border-color: #4ADDD5 !important; }
    .topnav-link { transition: border-color .2s, opacity .3s; opacity: 0; pointer-events: none; }
    .topnav-link:hover { border-bottom-color: #4ADDD5; }
    #topnav.solid .topnav-link { opacity: 1; pointer-events: auto; }
    /* ── Menú hamburguesa mòbil ─────────────────────────── */
    .hamburger {
      display: none;
      flex-direction: column;
      gap: 5px;
      cursor: pointer;
      background: none;
      border: none;
      padding: 4px;
      -webkit-tap-highlight-color: transparent;
    }
    .hamburger span {
      display: block;
      width: 22px;
      height: 2px;
      background: #000;
      transition: all .3s ease;
    }
    .mobile-menu {
      display: none;
      position: fixed;
      inset: 0;
      background: #000;
      z-index: 999;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      gap: 0;
    }
    .mobile-menu.open { display: flex; }
    .mobile-menu-close {
      position: absolute;
      top: 20px;
      right: 24px;
      background: none;
      border: none;
      color: #fff;
      font-size: 28px;
      cursor: pointer;
      -webkit-tap-highlight-color: transparent;
    }
    .mobile-menu a {
      font-size: clamp(24px, 8vw, 40px);
      font-weight: 800;
      color: #fff;
      text-decoration: none;
      letter-spacing: -.02em;
      padding: 16px 0;
      width: 100%;
      text-align: center;
      border-bottom: 1px solid rgba(255,255,255,.08);
    }
    .mobile-menu a:last-child { border-bottom: none; }
    @media (max-width: 900px) {
      .hamburger { display: flex; }
    }

    /* ── Noticias i vídeo ───────────────────────────────── */
    .resum-truncated {
      display: -webkit-box;
      -webkit-line-clamp: 3;
      -webkit-box-orient: vertical;
      overflow: hidden;
    }
    .video-thumb { position: relative; cursor: pointer; background: #000; aspect-ratio: 16/9; overflow: hidden; }
    .video-thumb img { width: 100%; height: 100%; object-fit: cover; opacity: .85; transition: opacity .2s; display: block; }
    .video-thumb:hover img { opacity: 1; }
    .video-play { position: absolute; inset: 0; display: flex; align-items: center; justify-content: center; }
    .video-play-btn { width: 52px; height: 52px; background: #4ADDD5; border-radius: 50%; display: flex; align-items: center; justify-content: center; }
    .video-play-btn svg { margin-left: 4px; }
    .news-card-img { height: 160px; overflow: hidden; position: relative; background: #eee; }
    .news-card-img img { width: 100%; height: 100%; object-fit: cover; }
    /* Scroll-reveal */
    .reveal { opacity: 0; transform: translateY(24px);
      transition: opacity .5s, transform .5s; }
    .reveal.visible { opacity: 1; transform: none; }
    .reveal-group > * { opacity: 0; transform: translateY(20px);
      transition: opacity .45s, transform .45s; }
    .reveal-group.visible > *:nth-child(1) { transition-delay: .05s; }
    .reveal-group.visible > *:nth-child(2) { transition-delay: .12s; }
    .reveal-group.visible > *:nth-child(3) { transition-delay: .19s; }
    .reveal-group.visible > *:nth-child(4) { transition-delay: .26s; }
    .reveal-group.visible > *:nth-child(5) { transition-delay: .33s; }
    .reveal-group.visible > * { opacity: 1; transform: none; }
    @media (prefers-reduced-motion: reduce) {
      .reveal, .reveal-group > * { opacity: 1; transform: none; transition: none; }
    }

    /* Secciones de color */
    .section-dark { background: #000; color: #fff; }
    .section-dark .section-title { color: #fff; }
    .section-tq { background: var(--tq); color: #000; }

    /* Mobile */
        @media (max-width: 900px) {
      .news-band-sub { display: none; }
      .news-band-coin { width: 38px; height: 38px; }
      #topnav { padding: 0 20px; }
      #topnav.solid { padding: 0 20px; }
      .topnav-nav { display: none; }
      .topnav-btn-contacte { display: none; }
      .content-width { padding: 0 20px; }
      .section-pad { padding: 56px 0; }
      .about-grid, .linies-grid-top, .linies-grid-bot,
      .news-grid, .doc-grid, .video-inner {
        grid-template-columns: 1fr !important;
      }
      #contacte .reveal { grid-template-columns: 1fr !important; }
      .news-secondary-col { flex-direction: row !important; flex-wrap: wrap; gap: 16px !important; }
      .news-secondary-col .news-card { width: calc(50% - 8px); }
    }
  
  </style>
</head>
<body>

<div id="traveller"></div>

<nav id="topnav">
  <div style="display:flex;align-items:center;gap:10px;">
    <img onclick="smoothScrollTo(0)" style="cursor:pointer;" src="data:image/png;base64," alt="SCPC-ACAPIR" />
  </div>
  <nav class="topnav-nav">
    <a class="topnav-link" href="#qui-som"><span data-lang="ca">Qui som</span><span data-lang="es">Quiénes somos</span></a>
    <a class="topnav-link" href="#linies"><span data-lang="ca">Línies de treball</span><span data-lang="es">Líneas de trabajo</span></a>
    <a class="topnav-link" href="#actualitat"><span data-lang="ca">Actualitat</span><span data-lang="es">Actualidad</span></a>
    <a class="topnav-link" href="#documentacio"><span data-lang="ca">Documentació</span><span data-lang="es">Documentación</span></a>
  </nav>
  <div class="topnav-controls">
    <div style="display:flex;align-items:center;gap:2px;">
      <button class="lang-btn active" id="btn-ca" onclick="setLang('ca')">CAT</button>
      <span style="font-size:11px;color:#ccc;">|</span>
      <button class="lang-btn" id="btn-es" onclick="setLang('es')">ES</button>
    </div>
    <a href="#contacte" class="btn-tq topnav-btn-contacte" style="padding:7px 16px;font-size:11px;">
      <span data-lang="ca">Contacte</span><span data-lang="es">Contacto</span>
    </a>
  </div>
</nav>

{{ content | safe }}

</body>
</html>
