<script>
  function setLang(lang) {
    document.body.classList.toggle('lang-es', lang === 'es');
    document.getElementById('btn-ca').classList.toggle('active', lang === 'ca');
    document.getElementById('btn-es').classList.toggle('active', lang === 'es');
    document.documentElement.lang = lang === 'es' ? 'es' : 'ca';
  }

  function updateTopnav() {
    var nav = document.getElementById('topnav');
    if (nav) nav.classList.toggle('solid', (window.scrollY || window.pageYOffset) > 40);
  }
  window.addEventListener('scroll', updateTopnav, { passive: true });

  function smoothScrollTo(targetY) {
    var startY = window.scrollY || window.pageYOffset;
    var diff = targetY - startY;
    if (Math.abs(diff) < 2) return;
    var dur = Math.min(700, Math.max(300, Math.abs(diff) * 0.4));
    var startTime = null;
    function ease(t) { return t < .5 ? 2*t*t : -1+(4-2*t)*t; }
    function step(ts) {
      if (!startTime) startTime = ts;
      var p = Math.min((ts - startTime) / dur, 1);
      window.scrollTo(0, startY + diff * ease(p));
      if (p < 1) requestAnimationFrame(step);
    }
    requestAnimationFrame(step);
  }

  function scrollToId(id) {
    var el = document.getElementById(id);
    if (!el) return;
    var nav = document.getElementById('topnav');
    var navH = nav ? nav.offsetHeight : 52;
    var scrollY = window.scrollY || window.pageYOffset;
    smoothScrollTo(Math.round(el.getBoundingClientRect().top + scrollY - navH));
  }

  function bandClick(band, evt, sectionId) {
    document.querySelectorAll('.hero-bands .band').forEach(function(b) {
      b.classList.remove('active');
    });
    if (band && band.classList && band.classList.contains('band')) {
      band.classList.add('active');
    }
    scrollToId(sectionId);
  }

  window.addEventListener('DOMContentLoaded', function() {
    document.querySelectorAll('.hero-bands .band[data-section]').forEach(function(btn) {
      var touchStartY = 0, touchStartX = 0;
      btn.addEventListener('touchstart', function(e) {
        touchStartY = e.touches[0].clientY;
        touchStartX = e.touches[0].clientX;
      }, { passive: true });
      btn.addEventListener('touchend', function(e) {
        var dy = Math.abs(e.changedTouches[0].clientY - touchStartY);
        var dx = Math.abs(e.changedTouches[0].clientX - touchStartX);
        if (dy < 10 && dx < 10) {
          e.preventDefault();
          scrollToId(btn.getAttribute('data-section'));
        }
      });
    });

    var newsBand = document.querySelector('.news-band');
    if (newsBand) {
      var nbY = 0, nbX = 0;
      newsBand.addEventListener('touchstart', function(e) {
        nbY = e.touches[0].clientY; nbX = e.touches[0].clientX;
      }, { passive: true });
      newsBand.addEventListener('touchend', function(e) {
        var dy = Math.abs(e.changedTouches[0].clientY - nbY);
        var dx = Math.abs(e.changedTouches[0].clientX - nbX);
        if (dy < 10 && dx < 10) { e.preventDefault(); scrollToId('actualitat'); }
      });
    }

    if (!window.IntersectionObserver) {
      document.querySelectorAll('.reveal,.reveal-group').forEach(function(el) {
        el.classList.add('visible');
      });
      return;
    }
    var io = new IntersectionObserver(function(entries) {
      entries.forEach(function(e) {
        if (!e.isIntersecting) return;
        e.target.classList.add('visible');
        io.unobserve(e.target);
      });
    }, { threshold: 0.12 });
    document.querySelectorAll('.reveal,.reveal-group').forEach(function(el) {
      io.observe(el);
    });
  });
  function newsGoPage(page) {
    document.querySelectorAll('.news-page').forEach(function(p) {
      p.style.display = p.getAttribute('data-page') == page ? '' : 'none';
    });
    document.querySelectorAll('[data-newspage]').forEach(function(b) {
      var active = b.getAttribute('data-newspage') == page;
      b.style.background = active ? '#000' : '#fff';
      b.style.color = active ? '#fff' : '#000';
      b.style.borderColor = active ? '#000' : '#ddd';
    });
    // Scroll suau a la secció de noticias
    scrollToId('actualitat');
  }

  function getVideoId(url) {
    if (!url) return null;
    var yt = url.match(/(?:youtube\.com\/watch\?v=|youtu\.be\/)([\w-]{11})/);
    if (yt) return { type: 'youtube', id: yt[1] };
    var vm = url.match(/vimeo\.com\/(\d+)/);
    if (vm) return { type: 'vimeo', id: vm[1] };
    return null;
  }
  function initVideos() {
    document.querySelectorAll('[data-video]').forEach(function(el) {
      var url = el.getAttribute('data-video');
      var info = getVideoId(url);
      if (!info) return;
      var thumb = info.type === 'youtube'
        ? 'https://img.youtube.com/vi/' + info.id + '/hqdefault.jpg'
        : 'https://vumbnail.com/' + info.id + '.jpg';
      var embedUrl = info.type === 'youtube'
        ? 'https://www.youtube.com/embed/' + info.id + '?autoplay=1'
        : 'https://player.vimeo.com/video/' + info.id + '?autoplay=1';
      el.innerHTML = '<div class="video-thumb"><img src="' + thumb + '" loading="lazy" /><div class="video-play"><div class="video-play-btn"><svg width="18" height="18" viewBox="0 0 24 24" fill="#000"><polygon points="5,3 19,12 5,21"/></svg></div></div></div>';
      el.querySelector('.video-thumb').onclick = function() {
        el.innerHTML = '<iframe src="' + embedUrl + '" style="width:100%;aspect-ratio:16/9;border:none;" allowfullscreen allow="autoplay"></iframe>';
      };
    });
  }
  window.addEventListener('DOMContentLoaded', function() {
    initVideos();
  });

  function getEmbedUrl(url) {
    if (!url) return null;
    // YouTube
    var ytMatch = url.match(/(?:youtube\.com\/watch\?v=|youtu\.be\/)([\w-]{11})/);
    if (ytMatch) return 'https://www.youtube.com/embed/' + ytMatch[1];
    // Vimeo
    var vimeoMatch = url.match(/vimeo\.com\/(\d+)/);
    if (vimeoMatch) return 'https://player.vimeo.com/video/' + vimeoMatch[1];
    return null;
  }

  function toggleExpand(btn, cosEl) {
    var open = cosEl.style.display !== 'none';
    cosEl.style.display = open ? 'none' : 'block';
    var caSpan = btn.querySelector('.btn-text-ca');
    var esSpan = btn.querySelector('.btn-text-es');
    if (caSpan) caSpan.textContent = open ? 'Llegir més' : 'Tancar';
    if (esSpan) esSpan.textContent = open ? 'Leer más' : 'Cerrar';
  }

</script>
