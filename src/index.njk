---
layout: layouts/base.njk
---

<section id="hero">
  <div class="hero-bands">

    <button class="band" type="button" data-section="qui-som" onclick="bandClick(this,event,'qui-som')">
      <span class="band-num">01</span>
      <span class="band-content-wrap">
        <span class="band-title" data-lang="ca">{{ config.hero.s01_ca }}</span>
        <span class="band-title" data-lang="es">{{ config.hero.s01_es }}</span>
      </span>
    </button>

    <button class="band" type="button" data-section="linies" onclick="bandClick(this,event,'linies')">
      <span class="band-num">02</span>
      <span class="band-content-wrap">
        <span class="band-title" data-lang="ca">{{ config.hero.s02_ca }}</span>
        <span class="band-title" data-lang="es">{{ config.hero.s02_es }}</span>
      </span>
    </button>

    <button class="band" type="button" data-section="actualitat" onclick="bandClick(this,event,'actualitat')">
      <span class="band-num">03</span>
      <span class="band-content-wrap">
        <span class="band-title" data-lang="ca">{{ config.hero.s03_ca }}</span>
        <span class="band-title" data-lang="es">{{ config.hero.s03_es }}</span>
      </span>
    </button>

    <button class="band" type="button" data-section="documentacio" onclick="bandClick(this,event,'documentacio')">
      <span class="band-num">04</span>
      <span class="band-content-wrap">
        <span class="band-title" data-lang="ca">{{ config.hero.s04_ca }}</span>
        <span class="band-title" data-lang="es">{{ config.hero.s04_es }}</span>
      </span>
    </button>

  </div>

  <div class="news-band" role="button" tabindex="0"
    onclick="bandClick(this,event,'actualitat');"
    onkeydown="if(event.key==='Enter')bandClick(this,event,'actualitat');">
    <div class="news-band-bg" style="background-image:url('{% if config.nou.imatge %}{{ config.nou.imatge }}{% else %}/assets/img/informe-2026.jpg{% endif %}');"></div>
    <div class="news-band-coin">
      <span class="news-band-coin-label"><span data-lang="ca">NOU</span><span data-lang="es">NUEVO</span></span>
      <span class="news-band-coin-date">{{ config.nou.data }}</span>
    </div>
    <div class="news-band-text">
      <span class="news-band-eyebrow"><span data-lang="ca">Informe SCPC-ACAPIR</span><span data-lang="es">Informe SCPC-ACAPIR</span></span>
      <span class="news-band-title">
        <span data-lang="ca">{{ config.nou.ca }}</span>
        <span data-lang="es">{{ config.nou.es }}</span>
      </span>
    </div>
  </div>
</section>

<div class="section-divider"></div>

<!-- QUI SOM -->
<section id="qui-som" class="section-pad" style="background:#fff;">
  <div class="content-width">
    <div class="section-header reveal">
      <div class="section-header-text">
        <div class="accent-line"></div>
        <p class="section-eyebrow"><span data-lang="ca">01 — Qui som</span><span data-lang="es">01 — Quiénes somos</span></p>
        <h2 class="section-title"><span data-lang="ca">Qui som.</span><span data-lang="es">Quiénes somos.</span></h2>
      </div>
    </div>
    <div class="about-grid reveal-group" style="display:grid;grid-template-columns:1fr 1fr;gap:32px;margin-bottom:48px;">
      <div>
        <p style="font-size:clamp(15px,1.3vw,18px);font-weight:300;line-height:1.8;color:#333;">
          <span data-lang="ca">{{ config.presentacio.ca }}</span>
          <span data-lang="es">{{ config.presentacio.es }}</span>
        </p>
      </div>
      <div style="background:#f8f8f8;padding:28px 32px;border-left:3px solid #4ADDD5;">
        <p style="font-size:clamp(14px,1.1vw,16px);font-weight:600;margin-bottom:8px;">
          <span data-lang="ca">{{ config.associa.titol_ca }}</span>
          <span data-lang="es">{{ config.associa.titol_es }}</span>
        </p>
        <p style="font-size:13px;font-weight:300;color:#555;line-height:1.6;margin-bottom:20px;">
          <span data-lang="ca">{{ config.associa.text_ca }}</span>
          <span data-lang="es">{{ config.associa.text_es }}</span>
        </p>
        <a href="{{ config.associa.link }}" target="_blank" rel="noopener" class="btn-outline-black">
          <span data-lang="ca">{{ config.associa.btn_ca }}</span><span data-lang="es">{{ config.associa.btn_es }}</span>
        </a>
      </div>
    </div>

    <div class="reveal" style="margin-top:40px;">
      <p style="font-size:11px;font-weight:700;letter-spacing:.14em;text-transform:uppercase;color:#999;margin-bottom:20px;">
        <span data-lang="ca">Junta Directiva</span><span data-lang="es">Junta Directiva</span>
      </p>
      <div style="display:grid;grid-template-columns:{% if junta.foto_grup %}2fr 1fr{% else %}1fr{% endif %};gap:32px;align-items:start;">
        <div class="junta-grid">
          {% for m in junta.membres %}
          <div class="junta-cell{% if m.vocal %} is-vocal{% endif %}" style="{% if m.foto and m.foto != \"\"%}display:flex;align-items:center;gap:12px;{% endif %}">
            {% if m.foto and m.foto != "" %}
            <img src="{{ m.foto }}" alt="{{ m.nom }}"
              style="width:56px;height:56px;border-radius:50%;object-fit:cover;flex-shrink:0;border:2px solid #4ADDD5;filter:grayscale(100%);transition:filter .3s;"
              onmouseover="this.style.filter='grayscale(0%)'"
              onmouseout="this.style.filter='grayscale(100%)'"
            />
            {% endif %}
            <div>
              <div class="junta-role">
                <span data-lang="ca">{{ m.rol_ca }}</span>
                <span data-lang="es">{{ m.rol_es }}</span>
              </div>
              <div class="junta-name">{{ m.nom }}</div>
            </div>
          </div>
          {% endfor %}
        </div>
        {% if junta.foto_grup %}
        <div>
          <img src="{{ junta.foto_grup }}" alt="Junta Directiva SCPC-ACAPIR"
            style="width:100%;aspect-ratio:4/3;object-fit:cover;" />
        </div>
        {% endif %}
      </div>
    </div>
  </div>
</section>

<div class="section-divider"></div>

<!-- LÍNIES DE TREBALL -->
<section id="linies" class="section-pad section-dark">
  <div class="content-width">
    <div class="section-header reveal">
      <div class="section-header-text">
        <div class="accent-line"></div>
        <p class="section-eyebrow"><span data-lang="ca">02 — Línies de treball</span><span data-lang="es">02 — Líneas de trabajo</span></p>
        <h2 class="section-title"><span data-lang="ca">Línies de treball.</span><span data-lang="es">Líneas de trabajo.</span></h2>
      </div>
    </div>
    <ul style="list-style:none;display:flex;flex-direction:column;gap:20px;" class="reveal-group">
      {% for item in linies.items %}
      <li style="display:flex;align-items:flex-start;gap:16px;">
        <span style="flex-shrink:0;width:10px;height:10px;border-radius:50%;background:#4ADDD5;margin-top:7px;"></span>
        <span style="font-size:clamp(14px,1.2vw,17px);font-weight:300;line-height:1.7;color:rgba(255,255,255,.85);">
          <span data-lang="ca">{{ item.ca }}</span>
          <span data-lang="es">{{ item.es }}</span>
        </span>
      </li>
      {% endfor %}
    </ul>
  </div>
</section>

<div class="section-divider"></div>

<!-- ACTUALITAT -->
<section id="actualitat" class="section-pad section-tq">
  <div class="content-width">
    <div class="section-header reveal">
      <div class="section-header-text">
        <div class="accent-line"></div>
        <p class="section-eyebrow"><span data-lang="ca">03 — Actualitat i Novetats</span><span data-lang="es">03 — Actualidad y Novedades</span></p>
        <h2 class="section-title"><span data-lang="ca">Notícies.</span><span data-lang="es">Noticias.</span></h2>
      </div>
    </div>
    <!-- Paginació JS: max 4 noticias per pàgina (1 destacada + 3 secundàries) -->
    <div id="news-container">
      {% for noticia in collections.noticias %}
      {% set ni = loop.index0 %}
      {% set page = (ni / 4) | int + 1 %}

      {% if ni % 4 == 0 %}
      <div class="news-page" data-page="{{ page }}"{% if page > 1 %} style="display:none;"{% endif %}>
        {% if ni == 0 %}
        <div class="news-grid reveal-group" style="display:grid;grid-template-columns:1fr 1fr;gap:24px;">
        {% else %}
        <div class="news-grid-2 reveal-group" style="display:grid;grid-template-columns:1fr 1fr;gap:24px;">
        {% endif %}
      {% endif %}

      {% if ni == 0 %}
        <!-- Notícia destacada -->
        <div class="news-card news-card-featured" style="display:flex;flex-direction:column;">
          <div style="height:260px;overflow:hidden;position:relative;">
            {% if noticia.data.image %}
            <img src="{{ noticia.data.image }}" alt="{{ noticia.data.title_ca }}" style="width:100%;height:100%;object-fit:cover;object-position:center 20%;" />
            {% else %}
            <div style="width:100%;height:100%;background:#000;display:flex;align-items:center;justify-content:center;">
              <span style="font-size:48px;color:rgba(255,255,255,.1);">✦</span>
            </div>
            {% endif %}
            <div style="position:absolute;inset:0;background:linear-gradient(to bottom,rgba(0,0,0,.1),rgba(0,0,0,.45));"></div>
            <span style="position:absolute;top:16px;left:16px;background:#4ADDD5;color:#000;font-size:10px;font-weight:700;letter-spacing:.1em;text-transform:uppercase;padding:4px 10px;">
              {{ noticia.date | dataFormat }}
            </span>
          </div>
          <div style="padding:28px 28px 32px;background:#fff;flex:1;">
            <h3 style="font-size:20px;font-weight:800;line-height:1.2;letter-spacing:-.01em;margin-bottom:12px;">
              <span data-lang="ca">{{ noticia.data.title_ca }}</span>
              <span data-lang="es">{{ noticia.data.title_es }}</span>
            </h3>
            {% if noticia.data.resum_ca %}
            <div id="resum-featured" style="margin-bottom:16px;">
              <p class="resum-truncated" style="font-size:14px;font-weight:300;line-height:1.7;color:#555;">
                <span data-lang="ca">{{ noticia.data.resum_ca | linkify | safe }}</span>
                <span data-lang="es">{{ noticia.data.resum_es | linkify | safe }}</span>
              </p>
            </div>
            {% endif %}
            {% if noticia.data.resum_ca or noticia.data.cos_ca %}
            <button onclick="
              var scrollY = window.scrollY;
              var wrap = document.getElementById('resum-featured');
              var cos = document.getElementById('cos-featured');
              var p = wrap ? wrap.querySelector('p') : null;
              var open = this.getAttribute('data-open') === '1';
              if (!open) {
                if (p) p.classList.remove('resum-truncated');
                if (cos) cos.style.display = 'block';
                this.setAttribute('data-open','1');
                this.querySelector('.btn-text-ca').textContent = 'Tancar';
                this.querySelector('.btn-text-es').textContent = 'Cerrar';
              } else {
                if (p) p.classList.add('resum-truncated');
                if (cos) cos.style.display = 'none';
                this.setAttribute('data-open','0');
                this.querySelector('.btn-text-ca').textContent = 'Llegir més';
                this.querySelector('.btn-text-es').textContent = 'Leer más';
                requestAnimationFrame(function(){ requestAnimationFrame(function(){
                  var card = document.querySelector('.news-card-featured');
                  if (card) {
                    var top = card.getBoundingClientRect().top + window.scrollY - 96;
                    window.scrollTo({ top: Math.max(0, top), behavior: 'instant' });
                  }
                }); });
              }
            " data-open="0" style="display:inline-block;background:none;border:none;padding:0;cursor:pointer;font-size:13px;font-weight:500;color:#000;text-decoration:underline;text-decoration-color:#4ADDD5;text-underline-offset:3px;margin-bottom:16px;font-family:inherit;touch-action:manipulation;">
              <span class="btn-text-ca" data-lang="ca">Llegir més</span>
              <span class="btn-text-es" data-lang="es">Leer más</span>
            </button>
            <div id="cos-featured" style="display:none;padding-top:16px;border-top:1px solid #eee;">
              {% if noticia.data.cos_ca %}
              <div style="font-size:14px;font-weight:300;line-height:1.8;color:#444;margin-bottom:16px;">
                <span data-lang="ca">{{ noticia.data.cos_ca | linkify | safe }}</span>
                <span data-lang="es">{{ noticia.data.cos_es | linkify | safe }}</span>
              </div>
              {% endif %}
              {% if noticia.data.link %}
              <a href="{{ noticia.data.link }}"{% if noticia.data.link and "://" in noticia.data.link %} target="_blank" rel="noopener"{% endif %}
                style="font-size:12px;font-weight:600;color:#000;text-decoration:underline;text-decoration-color:#4ADDD5;">
                <span data-lang="ca">{{ noticia.data.link_text_ca or "Accedir al document" }}</span>
                <span data-lang="es">{{ noticia.data.link_text_es or "Acceder al documento" }}</span>
              </a>
              {% endif %}
            </div>
            {% elif noticia.data.link %}
            <a href="{{ noticia.data.link }}"{% if noticia.data.link and "://" in noticia.data.link %} target="_blank" rel="noopener"{% endif %} class="btn-outline-black">
              <span data-lang="ca">{{ noticia.data.link_text_ca or "Llegir més" }}</span>
              <span data-lang="es">{{ noticia.data.link_text_es or "Leer más" }}</span>
            </a>
            {% endif %}
          </div>
        </div>
        <div class="news-secondary-col" style="display:flex;flex-direction:column;gap:20px;">
      {% else %}
        <!-- Notícia secundària -->
        <div class="news-card" style="display:flex;flex-direction:column;">
          {% if noticia.data.image %}
          <div class="news-card-img">
            <img src="{{ noticia.data.image }}" alt="{{ noticia.data.title_ca }}" loading="lazy" />
          </div>
          {% endif %}
          <div style="padding:20px 20px 24px;flex:1;">
            <p style="font-size:10px;color:#999;letter-spacing:.08em;text-transform:uppercase;margin-bottom:8px;">
              {{ noticia.date | dataFormat }}
            </p>
            <h3 style="font-size:15px;font-weight:700;line-height:1.3;margin-bottom:10px;">
              <span data-lang="ca">{{ noticia.data.title_ca }}</span>
              <span data-lang="es">{{ noticia.data.title_es }}</span>
            </h3>
            {% if noticia.data.cos_ca or noticia.data.resum_ca %}
            <button onclick="var c=this.nextElementSibling;var o=c.style.display!=='none';var sy=window.scrollY;c.style.display=o?'none':'block';this.textContent=o?'+ Llegir més':'− Tancar';if(o)requestAnimationFrame(function(){window.scrollTo(0,sy);});"
              style="font-size:12px;font-weight:500;color:#000;background:none;border:none;padding:0;cursor:pointer;text-decoration:underline;text-decoration-color:#4ADDD5;text-underline-offset:2px;touch-action:manipulation;">+ Llegir més</button>
            <div style="display:none;margin-top:10px;padding-top:10px;border-top:1px solid #eee;">
              <p style="font-size:13px;font-weight:300;line-height:1.7;color:#444;margin-bottom:10px;">
                <span data-lang="ca">{{ (noticia.data.cos_ca or noticia.data.resum_ca) | linkify | safe }}</span>
                <span data-lang="es">{{ (noticia.data.cos_es or noticia.data.resum_es) | linkify | safe }}</span>
              </p>
              {% if noticia.data.link %}
              <a href="{{ noticia.data.link }}"{% if noticia.data.link and "://" in noticia.data.link %} target="_blank" rel="noopener"{% endif %}
                style="font-size:12px;font-weight:600;color:#000;text-decoration:underline;text-decoration-color:#4ADDD5;">
                <span data-lang="ca">{{ noticia.data.link_text_ca or "Accedir" }}</span>
                <span data-lang="es">{{ noticia.data.link_text_es or "Acceder" }}</span>
              </a>
              {% endif %}
            </div>
            {% elif noticia.data.link %}
            <a href="{{ noticia.data.link }}"{% if noticia.data.link and "://" in noticia.data.link %} target="_blank" rel="noopener"{% endif %}
              style="font-size:12px;font-weight:600;color:#000;text-decoration:underline;text-decoration-color:#4ADDD5;">
              <span data-lang="ca">Llegir més</span><span data-lang="es">Leer más</span>
            </a>
            {% endif %}
          </div>
        </div>
      {% endif %}

      {% if ni % 4 == 3 or loop.last %}
        {% if ni == 3 or (ni < 3 and loop.last) %}
        </div><!-- fi secondary-col -->
        {% endif %}
        </div><!-- fi news-grid -->
      </div><!-- fi news-page -->
      {% endif %}
      {% endfor %}
    </div><!-- fi news-container -->

    <!-- Paginació -->
    {% set totalPages = ((collections.noticias.length - 1) / 4 + 1) | int %}
    {% if totalPages > 1 %}
    <div id="news-pagination" style="display:flex;align-items:center;justify-content:center;gap:8px;margin-top:32px;">
      {% for p in range(1, totalPages + 1) %}
      <button onclick="newsGoPage({{ p }})" data-newspage="{{ p }}"
        style="width:36px;height:36px;border:1px solid {% if p == 1 %}#000{% else %}#ddd{% endif %};background:{% if p == 1 %}#000{% else %}#fff{% endif %};color:{% if p == 1 %}#fff{% else %}#000{% endif %};font-size:13px;font-weight:600;cursor:pointer;font-family:inherit;touch-action:manipulation;">{{ p }}</button>
      {% endfor %}
    </div>
    {% endif %}

<div class="section-divider"></div>

<!-- DOCUMENTACIÓ -->
<section id="documentacio" class="section-pad section-dark">
  <div class="content-width">
    <div class="section-header reveal">
      <div class="section-header-text">
        <div class="accent-line"></div>
        <p class="section-eyebrow" style="color:rgba(255,255,255,.55);"><span data-lang="ca">04 — Documentació i Formació</span><span data-lang="es">04 — Documentación y Formación</span></p>
        <h2 class="section-title"><span data-lang="ca">Recursos.</span><span data-lang="es">Recursos.</span></h2>
      </div>
    </div>

    {% if config.documentacio.intro_ca %}
    <p class="reveal" style="font-size:clamp(14px,1.1vw,16px);font-weight:300;line-height:1.7;color:rgba(255,255,255,.6);margin-bottom:40px;max-width:700px;">
      <span data-lang="ca">{{ config.documentacio.intro_ca }}</span>
      <span data-lang="es">{{ config.documentacio.intro_es }}</span>
    </p>
    {% endif %}

    <!-- Recursos principals -->
    <div class="doc-grid reveal-group" style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:16px;margin-bottom:48px;">
      {% for recurs in collections.recursos %}
      <div class="resource-card" style="{% if recurs.data.destacat %}border-color:#4ADDD5;background:rgba(74,221,213,.04);{% endif %}padding:0;overflow:hidden;">
        {% if recurs.data.image %}
        <div style="height:110px;overflow:hidden;position:relative;">
          <img src="{{ recurs.data.image }}" alt="{{ recurs.data.title_ca }}" style="width:100%;height:100%;object-fit:cover;object-position:center 15%;" />
          <div style="position:absolute;inset:0;background:rgba(0,0,0,.35);"></div>
          <span style="position:absolute;top:12px;left:12px;font-size:10px;font-weight:700;letter-spacing:.1em;text-transform:uppercase;color:#000;background:#4ADDD5;padding:3px 8px;">
            {{ recurs.data.tipus }}
          </span>
        </div>
        <div style="padding:24px 28px 28px;">
        {% else %}
        <div style="padding:24px 28px 28px;">
          {% if recurs.data.tipus %}
          <span style="font-size:10px;font-weight:700;letter-spacing:.1em;text-transform:uppercase;color:#4ADDD5;display:block;margin-bottom:12px;">{{ recurs.data.tipus }}</span>
          {% endif %}
        {% endif %}
        <h3 style="font-size:15px;font-weight:700;margin-bottom:8px;line-height:1.3;">
          <span data-lang="ca">{{ recurs.data.title_ca }}</span>
          <span data-lang="es">{{ recurs.data.title_es }}</span>
        </h3>
        {% if recurs.data.resum_ca %}
        <p style="font-size:13px;font-weight:300;line-height:1.65;color:rgba(255,255,255,.55);margin-bottom:16px;">
          <span data-lang="ca">{{ recurs.data.resum_ca }}</span>
          <span data-lang="es">{{ recurs.data.resum_es }}</span>
        </p>
        {% endif %}
        {% if recurs.data.autors %}
        <p style="font-size:12px;font-weight:300;color:rgba(255,255,255,.45);margin-bottom:6px;">{{ recurs.data.autors }}</p>
        {% endif %}
        {% if recurs.data.isbn %}
        <p style="font-size:12px;font-weight:300;color:rgba(255,255,255,.35);margin-bottom:16px;">ISBN {{ recurs.data.isbn }} · {{ recurs.data.llicencia }}</p>
        {% endif %}
        <a href="{{ recurs.data.link }}" target="_blank" rel="noopener" class="btn-outline-white">
          <span data-lang="ca">Accedir al document</span><span data-lang="es">Acceder al documento</span>
        </a>
        </div>
      </div>
      {% endfor %}
    </div>

    <!-- Documents institucionals (només si n'hi ha) -->
    {% if collections.documents and collections.documents.length > 0 %}
    <div class="reveal" style="margin-top:40px;padding-top:40px;border-top:1px solid rgba(255,255,255,.1);">
      <p style="font-size:11px;font-weight:700;letter-spacing:.14em;text-transform:uppercase;color:rgba(255,255,255,.4);margin-bottom:20px;">
        <span data-lang="ca">Documents institucionals</span><span data-lang="es">Documentos institucionales</span>
      </p>
      <div style="display:flex;flex-direction:column;gap:10px;">
        {% for doc in collections.documents %}
        <a href="{{ doc.data.fitxer }}" target="_blank" rel="noopener"
          style="display:flex;align-items:center;justify-content:space-between;padding:14px 18px;border:1px solid rgba(255,255,255,.1);text-decoration:none;transition:border-color .2s;">
          <div>
            <span style="font-size:13px;font-weight:500;color:#fff;display:block;margin-bottom:3px;">
              <span data-lang="ca">{{ doc.data.title_ca }}</span>
              <span data-lang="es">{{ doc.data.title_es }}</span>
            </span>
            {% if doc.data.descripcio_ca %}
            <span style="font-size:12px;color:rgba(255,255,255,.45);">
              <span data-lang="ca">{{ doc.data.descripcio_ca }}</span>
              <span data-lang="es">{{ doc.data.descripcio_es }}</span>
            </span>
            {% endif %}
          </div>
          <span style="font-size:10px;font-weight:700;letter-spacing:.1em;color:#4ADDD5;flex-shrink:0;margin-left:16px;">PDF ↓</span>
        </a>
        {% endfor %}
      </div>
    </div>
    {% endif %}

    <!-- Arxiu de formació -->
    <div class="reveal">
      <p style="font-size:11px;font-weight:700;letter-spacing:.14em;text-transform:uppercase;color:rgba(255,255,255,.4);margin-bottom:12px;">
        <span data-lang="ca">Arxiu de formació</span><span data-lang="es">Archivo de formación</span>
      </p>
      {% if config.formacio.intro_ca %}
      <p style="font-size:13px;font-weight:300;color:rgba(255,255,255,.5);margin-bottom:20px;line-height:1.6;">
        <span data-lang="ca">{{ config.formacio.intro_ca }}</span>
        <span data-lang="es">{{ config.formacio.intro_es }}</span>
      </p>
      {% endif %}
      <div style="display:flex;flex-direction:column;gap:8px;">
        {% for item in collections.formacio %}
        <div style="border:1px solid rgba(255,255,255,.1);">
          <div style="display:flex;align-items:center;gap:12px;padding:14px 18px;">
            <span style="font-size:10px;font-weight:700;letter-spacing:.08em;color:#4ADDD5;flex-shrink:0;">
              {% set is_vid = item.data.video_url or (item.data.link and ('youtu' in item.data.link or 'vimeo' in item.data.link)) %}
              {% if is_vid %}▶{% else %}{{ item.data.tipus }}{% endif %}
            </span>
            <span style="font-size:13px;font-weight:500;color:rgba(255,255,255,.85);line-height:1.35;flex:1;">
              <span data-lang="ca">{{ item.data.title_ca }}</span>
              <span data-lang="es">{{ item.data.title_es }}</span>
            </span>
            <button onclick="
              var cos = this.closest('div').nextElementSibling;
              var open = cos.style.display !== 'none';
              cos.style.display = open ? 'none' : 'block';
              this.textContent = open ? '+' : '−';
            " style="background:none;border:none;color:#4ADDD5;font-size:18px;font-weight:300;cursor:pointer;flex-shrink:0;padding:0 4px;">+</button>
          </div>
          <div style="display:none;padding:0 18px 18px;">
            {% set vid_url = item.data.video_url or item.data.link %}
            {% if vid_url and ('youtu' in vid_url or 'vimeo' in vid_url) %}
            <div data-video="{{ vid_url }}" style="margin-bottom:12px;"></div>
            {% elif item.data.link %}
            <a href="{{ item.data.link }}"{% if item.data.link and "://" in item.data.link %} target="_blank" rel="noopener"{% endif %}
              style="display:inline-block;margin-top:10px;font-size:12px;font-weight:600;color:#4ADDD5;text-decoration:none;">
              <span data-lang="ca">Accedir al material</span><span data-lang="es">Acceder al material</span>
            </a>
            {% endif %}
            {% if item.data.descripcio_ca %}
            <p style="font-size:13px;font-weight:300;color:rgba(255,255,255,.6);line-height:1.6;margin-top:12px;">
              <span data-lang="ca">{{ item.data.descripcio_ca | linkify | safe }}</span>
              <span data-lang="es">{{ item.data.descripcio_es | linkify | safe }}</span>
            </p>
            {% endif %}
          </div>
        </div>
        {% endfor %}
      </div>
    </div>

  </div>
</section>

<div class="section-divider"></div>

