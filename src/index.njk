---
layout: layouts/base.njk
---

<section id="hero">
  <div class="hero-bands">

    <button class="band" type="button" data-section="qui-som" onclick="bandClick(this,event,'qui-som')">
      <span class="band-num">01</span>
      <span class="band-content-wrap">
        <span class="band-title" data-lang="ca">Qui som</span>
        <span class="band-title" data-lang="es">Quiénes somos</span>
      </span>
    </button>

    <button class="band" type="button" data-section="linies" onclick="bandClick(this,event,'linies')">
      <span class="band-num">02</span>
      <span class="band-content-wrap">
        <span class="band-title" data-lang="ca">Línies de treball</span>
        <span class="band-title" data-lang="es">Líneas de trabajo</span>
      </span>
    </button>

    <button class="band" type="button" data-section="actualitat" onclick="bandClick(this,event,'actualitat')">
      <span class="band-num">03</span>
      <span class="band-content-wrap">
        <span class="band-title" data-lang="ca">Actualitat</span>
        <span class="band-title" data-lang="es">Actualidad</span>
      </span>
    </button>

    <button class="band" type="button" data-section="documentacio" onclick="bandClick(this,event,'documentacio')">
      <span class="band-num">04</span>
      <span class="band-content-wrap">
        <span class="band-title" data-lang="ca">Documentació i Formació</span>
        <span class="band-title" data-lang="es">Documentación y Formación</span>
      </span>
    </button>

  </div>

  <div class="news-band" role="button" tabindex="0"
    onclick="bandClick(this,event,'actualitat');"
    onkeydown="if(event.key==='Enter')bandClick(this,event,'actualitat');">
    <div class="news-band-bg" style="background-image:url('{{ config.nou_destacat_img | default('/assets/img/informe-2026.jpg') }}');"></div>
    <div class="news-band-coin">
      <span class="news-band-coin-label"><span data-lang="ca">NOU</span><span data-lang="es">NUEVO</span></span>
      <span class="news-band-coin-date">{{ config.nou_destacat_data }}</span>
    </div>
    <div class="news-band-text">
      <span class="news-band-eyebrow"><span data-lang="ca">Informe SCPC-ACAPIR</span><span data-lang="es">Informe SCPC-ACAPIR</span></span>
      <span class="news-band-title">
        <span data-lang="ca">{{ config.nou_destacat_ca }}</span>
        <span data-lang="es">{{ config.nou_destacat_es }}</span>
      </span>
    </div>
  </div>
</section>

<div class="section-divider"></div>

<!-- QUI SOM -->
<section id="qui-som" class="section-pad" style="background:#fff;">
  <div class="content-width">
    <div class="section-header reveal">
      <div class="section-header-text">
        <div class="accent-line"></div>
        <p class="section-eyebrow"><span data-lang="ca">01 — Qui som</span><span data-lang="es">01 — Quiénes somos</span></p>
        <h2 class="section-title"><span data-lang="ca">La nostra associació.</span><span data-lang="es">Nuestra asociación.</span></h2>
      </div>
    </div>
    <div class="about-grid reveal-group" style="display:grid;grid-template-columns:1fr 1fr;gap:32px;margin-bottom:48px;">
      <div>
        <p style="font-size:clamp(15px,1.3vw,18px);font-weight:300;line-height:1.8;color:#333;">
          <span data-lang="ca">La Societat Catalana de Psicologia Clínica SCPC·ACAPIR és la secció territorial a Catalunya de la SEPC·ANPIR. A Catalunya ja som més de 400 sòcies i socis —entre especialistes i residents de Psicologia Clínica— que treballem activament per una atenció en salut mental pública, universal i de qualitat.</span>
          <span data-lang="es">La Societat Catalana de Psicologia Clínica SCPC·ACAPIR es la sección territorial en Catalunya de la SEPC·ANPIR. En Catalunya ya somos más de 400 socias y socios —entre especialistas y residentes de Psicología Clínica— que trabajamos activamente por una atención en salud mental pública, universal y de calidad.</span>
        </p>
      </div>
      <div style="background:#f8f8f8;padding:28px 32px;border-left:3px solid #4ADDD5;">
        <p style="font-size:11px;font-weight:700;letter-spacing:.14em;text-transform:uppercase;color:#999;margin-bottom:16px;">
          <span data-lang="ca">Junta Directiva</span><span data-lang="es">Junta Directiva</span>
        </p>
        <div class="junta-grid">
          {% for m in junta.membres %}
          <div class="junta-cell{% if m.vocal %} is-vocal{% endif %}">
            <div class="junta-role">
              <span data-lang="ca">{{ m.rol_ca }}</span>
              <span data-lang="es">{{ m.rol_es }}</span>
            </div>
            <div class="junta-name">{{ m.nom }}</div>
          </div>
          {% endfor %}
        </div>
      </div>
    </div>

    <div class="sub-strip reveal">
      <div>
        <p style="font-size:clamp(14px,1.1vw,16px);font-weight:600;margin-bottom:6px;">
          <span data-lang="ca">Vols formar part de la SCPC·ACAPIR?</span>
          <span data-lang="es">¿Quieres formar parte de la SCPC·ACAPIR?</span>
        </p>
        <p style="font-size:13px;font-weight:300;color:#555;line-height:1.6;">
          <span data-lang="ca">Per associar-te has de fer-te soci/a de la SEPC·ANPIR i marcar com a associació territorial la SCPC·ACAPIR.</span>
          <span data-lang="es">Para asociarte debes hacerte socio/a de la SEPC·ANPIR y marcar como asociación territorial la SCPC·ACAPIR.</span>
        </p>
      </div>
      <a href="https://www.anpir.org/socios/alta_socios.php" target="_blank" rel="noopener" class="btn-outline-black">
        <span data-lang="ca">Associa't</span><span data-lang="es">Asóciate</span>
      </a>
    </div>
  </div>
</section>

<div class="section-divider"></div>

<!-- LÍNIES DE TREBALL -->
<section id="linies" class="section-pad section-dark">
  <div class="content-width">
    <div class="section-header reveal">
      <div class="section-header-text">
        <div class="accent-line"></div>
        <p class="section-eyebrow"><span data-lang="ca">02 — Línies de treball</span><span data-lang="es">02 — Líneas de trabajo</span></p>
        <h2 class="section-title"><span data-lang="ca">Com actuem.</span><span data-lang="es">Cómo actuamos.</span></h2>
      </div>
    </div>
    <ul style="list-style:none;display:flex;flex-direction:column;gap:20px;" class="reveal-group">
      {% for item in linies.items %}
      <li style="display:flex;align-items:flex-start;gap:16px;">
        <span style="flex-shrink:0;width:10px;height:10px;border-radius:50%;background:#4ADDD5;margin-top:7px;"></span>
        <span style="font-size:clamp(14px,1.2vw,17px);font-weight:300;line-height:1.7;color:rgba(255,255,255,.85);">
          <span data-lang="ca">{{ item.ca }}</span>
          <span data-lang="es">{{ item.es }}</span>
        </span>
      </li>
      {% endfor %}
    </ul>
  </div>
</section>

<div class="section-divider"></div>

<!-- ACTUALITAT -->
<section id="actualitat" class="section-pad section-tq">
  <div class="content-width">
    <div class="section-header reveal">
      <div class="section-header-text">
        <div class="accent-line"></div>
        <p class="section-eyebrow"><span data-lang="ca">03 — Actualitat i Novetats</span><span data-lang="es">03 — Actualidad y Novedades</span></p>
        <h2 class="section-title"><span data-lang="ca">Últimes notícies.</span><span data-lang="es">Últimas noticias.</span></h2>
      </div>
    </div>
    <div class="news-grid reveal-group" style="display:grid;grid-template-columns:1fr 1fr;gap:24px;">
      {% for noticia in collections.noticias %}
        {% if loop.first %}
        <div class="news-card news-card-featured" style="display:flex;flex-direction:column;">
          <div style="height:260px;overflow:hidden;position:relative;">
            {% if noticia.data.image %}
            <img src="{{ noticia.data.image }}" alt="{{ noticia.data.title_ca }}" style="width:100%;height:100%;object-fit:cover;object-position:center 20%;" />
            {% else %}
            <div style="width:100%;height:100%;background:#000;display:flex;align-items:center;justify-content:center;">
              <span style="font-size:48px;color:rgba(255,255,255,.1);">✦</span>
            </div>
            {% endif %}
            <div style="position:absolute;inset:0;background:linear-gradient(to bottom,rgba(0,0,0,.1),rgba(0,0,0,.45));"></div>
            <span style="position:absolute;top:16px;left:16px;background:#4ADDD5;color:#000;font-size:10px;font-weight:700;letter-spacing:.1em;text-transform:uppercase;padding:4px 10px;">
              {{ noticia.data.date | dataFormat }}
            </span>
          </div>
          <div style="padding:28px 28px 32px;background:#fff;flex:1;">
            <h3 style="font-size:20px;font-weight:800;line-height:1.2;letter-spacing:-.01em;margin-bottom:16px;">
              <span data-lang="ca">{{ noticia.data.title_ca }}</span>
              <span data-lang="es">{{ noticia.data.title_es }}</span>
            </h3>
            {% if noticia.data.link %}
            <a href="{{ noticia.data.link }}" target="_blank" rel="noopener" class="btn-outline-black">
              <span data-lang="ca">Llegir més</span><span data-lang="es">Leer más</span>
            </a>
            {% endif %}
          </div>
        </div>
        <div style="display:flex;flex-direction:column;gap:24px;">
        {% else %}
        <div class="news-card" style="display:flex;flex-direction:column;">
          <div style="padding:24px 24px 28px;flex:1;">
            <p style="font-size:11px;color:#999;letter-spacing:.08em;text-transform:uppercase;margin-bottom:8px;">
              {{ noticia.data.date | dataFormat }}
            </p>
            <h3 style="font-size:16px;font-weight:700;line-height:1.3;margin-bottom:12px;">
              <span data-lang="ca">{{ noticia.data.title_ca }}</span>
              <span data-lang="es">{{ noticia.data.title_es }}</span>
            </h3>
            {% if noticia.data.link %}
            <a href="{{ noticia.data.link }}" target="_blank" rel="noopener" style="font-size:12px;font-weight:600;color:#000;text-decoration:underline;text-decoration-color:#4ADDD5;">
              <span data-lang="ca">Llegir més</span><span data-lang="es">Leer más</span>
            </a>
            {% endif %}
          </div>
        </div>
        {% endif %}
      {% endfor %}
      </div><!-- fi notícies anteriors -->
    </div>
  </div>
</section>

<div class="section-divider"></div>

<!-- DOCUMENTACIÓ -->
<section id="documentacio" class="section-pad section-dark">
  <div class="content-width">
    <div class="section-header reveal">
      <div class="section-header-text">
        <div class="accent-line"></div>
        <p class="section-eyebrow"><span data-lang="ca">04 — Documentació i Formació</span><span data-lang="es">04 — Documentación y Formación</span></p>
        <h2 class="section-title"><span data-lang="ca">Recursos.</span><span data-lang="es">Recursos.</span></h2>
      </div>
    </div>
    <div class="doc-grid reveal-group" style="display:grid;grid-template-columns:1fr 1fr;gap:20px;margin-bottom:40px;">
      {% for recurs in collections.recursos %}
      <div class="resource-card{% if recurs.data.destacat %} " style="border-color:#4ADDD5;background:rgba(74,221,213,.04);padding:0;overflow:hidden;"{% else %}"{% endif %}>
        {% if recurs.data.image %}
        <div style="height:140px;overflow:hidden;position:relative;">
          <img src="{{ recurs.data.image }}" alt="{{ recurs.data.title_ca }}" style="width:100%;height:100%;object-fit:cover;object-position:center 15%;" />
          <div style="position:absolute;inset:0;background:rgba(0,0,0,.35);"></div>
          <span style="position:absolute;top:12px;right:12px;font-size:10px;letter-spacing:.1em;text-transform:uppercase;color:rgba(255,255,255,.8);border:1px solid rgba(255,255,255,.3);padding:3px 8px;background:rgba(0,0,0,.3);">
            {{ recurs.data.date | dataFormat }}
          </span>
        </div>
        <div style="padding:24px 28px 28px;">
        {% endif %}
        <h3 style="font-size:18px;font-weight:700;margin-bottom:12px;line-height:1.3;">
          <span data-lang="ca">{{ recurs.data.title_ca }}</span>
          <span data-lang="es">{{ recurs.data.title_es }}</span>
        </h3>
        {% if recurs.data.autors %}
        <p style="font-size:13px;font-weight:300;line-height:1.7;color:rgba(255,255,255,.6);margin-bottom:8px;">{{ recurs.data.autors }}</p>
        {% endif %}
        {% if recurs.data.isbn %}
        <p style="font-size:12px;font-weight:300;color:rgba(255,255,255,.45);margin-bottom:24px;">ISBN {{ recurs.data.isbn }} · {{ recurs.data.llicencia }}</p>
        {% endif %}
        <a href="{{ recurs.data.link }}" target="_blank" rel="noopener" class="btn-outline-white">
          <span data-lang="ca">Accedir al document</span><span data-lang="es">Acceder al documento</span>
        </a>
        {% if recurs.data.image %}
        </div>
        {% endif %}
      </div>
      {% endfor %}
    </div>
  </div>
</section>

<div class="section-divider"></div>

<!-- CONTACTE -->
<section id="contacte" class="section-pad" style="background:#000;color:#fff;">
  <div class="content-width">
    <div class="section-header reveal">
      <div class="section-header-text">
        <div class="accent-line"></div>
        <p class="section-eyebrow" style="color:rgba(255,255,255,.4);"><span data-lang="ca">Contacte</span><span data-lang="es">Contacto</span></p>
        <h2 class="section-title" style="color:#fff;"><span data-lang="ca">Parlem.</span><span data-lang="es">Hablemos.</span></h2>
      </div>
    </div>
    <div style="display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:32px;" class="reveal">
      <div>
        <p style="font-size:clamp(20px,3vw,36px);font-weight:800;letter-spacing:-.02em;margin-bottom:8px;">
          <a href="mailto:{{ config.email }}" style="color:#4ADDD5;text-decoration:none;">{{ config.email }}</a>
        </p>
        <p style="font-size:12px;color:rgba(255,255,255,.4);margin-bottom:24px;">
          <span data-lang="ca">Secretaria de la SCPC·ACAPIR</span>
          <span data-lang="es">Secretaría de la SCPC·ACAPIR</span>
        </p>
        <div style="display:flex;gap:16px;">
          <a href="{{ config.twitter }}" target="_blank" rel="noopener" class="btn-outline-white">X / Twitter</a>
          <a href="{{ config.instagram }}" target="_blank" rel="noopener" class="btn-outline-white">Instagram</a>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  function setLang(lang) {
    document.body.classList.toggle('lang-es', lang === 'es');
    document.getElementById('btn-ca').classList.toggle('active', lang === 'ca');
    document.getElementById('btn-es').classList.toggle('active', lang === 'es');
    document.documentElement.lang = lang === 'es' ? 'es' : 'ca';
  }

  function updateTopnav() {
    var nav = document.getElementById('topnav');
    if (nav) nav.classList.toggle('solid', (window.scrollY || window.pageYOffset) > 40);
  }
  window.addEventListener('scroll', updateTopnav, { passive: true });

  function smoothScrollTo(targetY) {
    var startY = window.scrollY || window.pageYOffset;
    var diff = targetY - startY;
    if (Math.abs(diff) < 2) return;
    var dur = Math.min(700, Math.max(300, Math.abs(diff) * 0.4));
    var startTime = null;
    function ease(t) { return t < .5 ? 2*t*t : -1+(4-2*t)*t; }
    function step(ts) {
      if (!startTime) startTime = ts;
      var p = Math.min((ts - startTime) / dur, 1);
      window.scrollTo(0, startY + diff * ease(p));
      if (p < 1) requestAnimationFrame(step);
    }
    requestAnimationFrame(step);
  }

  function scrollToId(id) {
    var el = document.getElementById(id);
    if (!el) return;
    var nav = document.getElementById('topnav');
    var navH = nav ? nav.offsetHeight : 52;
    var scrollY = window.scrollY || window.pageYOffset;
    smoothScrollTo(Math.round(el.getBoundingClientRect().top + scrollY - navH));
  }

  function bandClick(band, evt, sectionId) {
    document.querySelectorAll('.hero-bands .band').forEach(function(b) {
      b.classList.remove('active');
    });
    if (band && band.classList && band.classList.contains('band')) {
      band.classList.add('active');
    }
    scrollToId(sectionId);
  }

  window.addEventListener('DOMContentLoaded', function() {
    document.querySelectorAll('.hero-bands .band[data-section]').forEach(function(btn) {
      var touchStartY = 0, touchStartX = 0;
      btn.addEventListener('touchstart', function(e) {
        touchStartY = e.touches[0].clientY;
        touchStartX = e.touches[0].clientX;
      }, { passive: true });
      btn.addEventListener('touchend', function(e) {
        var dy = Math.abs(e.changedTouches[0].clientY - touchStartY);
        var dx = Math.abs(e.changedTouches[0].clientX - touchStartX);
        if (dy < 10 && dx < 10) {
          e.preventDefault();
          scrollToId(btn.getAttribute('data-section'));
        }
      });
    });

    var newsBand = document.querySelector('.news-band');
    if (newsBand) {
      var nbY = 0, nbX = 0;
      newsBand.addEventListener('touchstart', function(e) {
        nbY = e.touches[0].clientY; nbX = e.touches[0].clientX;
      }, { passive: true });
      newsBand.addEventListener('touchend', function(e) {
        var dy = Math.abs(e.changedTouches[0].clientY - nbY);
        var dx = Math.abs(e.changedTouches[0].clientX - nbX);
        if (dy < 10 && dx < 10) { e.preventDefault(); scrollToId('actualitat'); }
      });
    }

    if (!window.IntersectionObserver) {
      document.querySelectorAll('.reveal,.reveal-group').forEach(function(el) {
        el.classList.add('visible');
      });
      return;
    }
    var io = new IntersectionObserver(function(entries) {
      entries.forEach(function(e) {
        if (!e.isIntersecting) return;
        e.target.classList.add('visible');
        io.unobserve(e.target);
      });
    }, { threshold: 0.12 });
    document.querySelectorAll('.reveal,.reveal-group').forEach(function(el) {
      io.observe(el);
    });
  });
</script>
